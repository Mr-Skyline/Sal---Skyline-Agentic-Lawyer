# Copy to .env in this folder (do not commit .env).

# Optional: verify_setup warns if cwd does not resolve to this path (unset = use repo root only)
# INTENDED_PROJECT_ROOT=D:\path\to\repo

# Optional: folder for Sal-style review Markdown (default: ./skyline_review under project root)
# SKYLINE_REVIEW_DIR=D:\path\to\repo\skyline_review

XAI_API_KEY=
# OCR: after core pip install, run: pip install -r requirements-ocr.txt
ZHIPU_API_KEY=
# Optional override (default grok-4.20-0309-reasoning)
# GROK_MODEL=
# Optional: max completion tokens for analysis JSON (default 1200)
# GROK_MAX_OUTPUT_TOKENS=1200
# Optional: override path to Sal system prompt (default: Skyline Lawyer – Full System Prompt.txt in project root)
# SAL_PROMPT_PATH=

# --- sync_worker (data plane) ---
# AGENT_GMAIL_ADDRESS=agent@yourdomain.com
# Local default (after: py ensure_correspondence_archive.py):
# CORRESPONDENCE_ARCHIVE_DIR=D:\path\to\repo\correspondence_archive
# Or UNC / share:
# CORRESPONDENCE_ARCHIVE_DIR=\\fileserver\share\LegalAgent\archive
# SYNC_POLL_INTERVAL_SEC=300
# SYNC_NEWER_THAN_DAYS=7
# Loop mode: max seconds between retries after an error (exponential backoff, capped)
# SYNC_WORKER_BACKOFF_CAP_SEC=300
# Loop mode: exit after N consecutive sync errors (0 = never; e.g. 10 with a supervisor)
# SYNC_WORKER_MAX_CONSECUTIVE_ERRORS=0
# State file (fixed path, not env): ./correspondence_sync_state.json next to main.py
# Preview threads via Gmail API (no archive/state/DB): py sync_worker.py --dry-run  (CORRESPONDENCE_ARCHIVE_DIR not required)

# Optional Supabase — pip install -r requirements-supabase.txt (not in core requirements.txt).
# Apply schema in dashboard, then: py verify_setup.py --supabase-ping
# SUPABASE_URL=https://xxxx.supabase.co
# Prefer service role for server-side worker; never expose in frontend apps.
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_KEY=

# Gmail OAuth loopback (must match Authorized redirect URIs in Google Cloud Web client)
# Default base port 8765; app tries OAUTH_LOCAL_PORT + next (TRY_COUNT-1) ports if busy.
# OAUTH_LOCAL_PORT=8765
# OAUTH_LOCAL_PORT_TRY_COUNT=5
# If py oauth_login.py opens Cursor instead of Chrome/Edge, paste the auth URL manually:
# OAUTH_OPEN_BROWSER=0
# If Google says redirect_uri_mismatch for 127.0.0.1 but Console only has localhost (or the reverse):
# OAUTH_LOOPBACK_HOST=localhost
