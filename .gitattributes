# Normalize line endings for cross-platform clones
* text=auto

# Windows batch / PowerShell must keep CRLF
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source and text files use LF
*.py text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.mdc text eol=lf

# Linguist overrides
docs/* linguist-documentation
